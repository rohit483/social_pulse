# Environment Variables — Local Development Template
# Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env to version control!

# =============================================================================
# APPLICATION
# =============================================================================
SECRET_KEY=your-secret-key-here

# =============================================================================
# INSTAGRAM CREDENTIALS
# =============================================================================
INSTAGRAM_USERNAME=your_instagram_username

# Optional: Override default Android User-Agent
INSTAGRAM_USER_AGENT=

# =============================================================================
# INSTAGRAM SESSIONS (auto-generated by Docker from cookie.json)
# =============================================================================
# These are automatically written here when Docker starts and cookie.json exists.
# You can also paste pre-generated B64 keys directly if you don't use cookie.json.
INSTAGRAPI_SESSION_B64=
INSTALOADER_SESSION_B64=

# =============================================================================
# POSTGRESQL DATABASE
# =============================================================================
POSTGRES_USER=ritz
POSTGRES_PASSWORD=your_local_password
POSTGRES_DB=social_pulse_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# =============================================================================
# AI / ANALYSIS (optional)
# =============================================================================
# Leave blank if not using OpenAI or HuggingFace models
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=

# =============================================================================
# STORAGE
# =============================================================================
# Leave blank to use the default path (webdata/csv downloads) inside Docker
DOWNLOAD_FOLDER=

# =============================================================================
# SERVER & SECURITY
# =============================================================================
# Set to 1 only for local development — NEVER in production!
FLASK_DEBUG=0

# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=http://localhost,http://localhost:5000

# Redis URL for persistent rate limiting (optional, falls back to in-memory)
# Example: redis://localhost:6379
REDIS_URL=
