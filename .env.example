# Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env to version control (add to .gitignore)

# =============================================================================
# APPLICATION
# =============================================================================
SECRET_KEY=your-secret-key-here-change-in-production

# =============================================================================
# INSTAGRAM CREDENTIALS (Local Development Only)
# =============================================================================
# Username for Instagram account scraping
INSTAGRAM_USERNAME=your_instagram_username

# (Optional) Add standard credentials below if needed for future extensions, 
# but Note: the scraper itself strictly uses the Base64 session variables below.

# =============================================================================
# INSTAGRAM SESSION (B64)
# =============================================================================
# The application strictly requires pre-authenticated sessions passed as B64 strings.
# Generate these locally using the 'insta_session' helper repository.
INSTAGRAPI_SESSION_B64=
INSTALOADER_SESSION_B64=

# =============================================================================
# DATABASE (Optional - for future use)
# =============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/social_pulse

# =============================================================================
# PRODUCTION DEPLOYMENT (Render)
# =============================================================================
# When deploying to Render:
# 1. Generate session locally with VPN: docker-compose up
# 2. Export session: python export_session.py
# 3. Set INSTAGRAPI_SESSION_B64 to the full base64 string
# 4. Set ALLOW_DIRECT_LOGIN=0
# 5. Deploy to Render
